{
  "name": "ironlog",
  "version": "1.6.0",
  "description": "A dark-themed, Hevy-inspired workout tracker for recomposition athletes. Track training, body composition, nutrition, and progress in a single-page app.",
  "private": true,
  "scripts": {
    "dev": "serve src -l 8080 --cors",
    "lint": "eslint src/js/",
    "lint:fix": "eslint src/js/ --fix",
    "format": "prettier --write \"src/**/*.{js,css,html}\"",
    "format:check": "prettier --check \"src/**/*.{js,css,html}\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/keerthanswarup00-bot/workout-tracker.git"
  },
  "keywords": ["workout", "fitness", "tracker", "pwa"],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/keerthanswarup00-bot/workout-tracker/issues"
  },
  "homepage": "https://github.com/keerthanswarup00-bot/workout-tracker#readme",
  "devDependencies": {
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "serve": "^14.2.6"
  }
}
